# IntelliJ, VS Code 등이 줄바꿈 규칙을 맞추도록 설정합니다.
# Windows에서 gradlew.bat이 LF로 바뀌며 pull이 막히는 문제를 방지합니다.

root = true

[*]
charset = utf-8
insert_final_newline = true

[*.bat]
end_of_line = crlf

[gradlew]
end_of_line = lf

[*.sh]
end_of_line = lf

[*.md]
end_of_line = lf

[*.java]
end_of_line = lf

[*.ts]
end_of_line = lf

[*.tsx]
end_of_line = lf

[*.json]
end_of_line = lf

[*.yml]
end_of_line = lf

[*.yaml]
end_of_line = lf
